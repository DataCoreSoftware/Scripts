#!/bin/bash
# Author: DataCore Software
#
# This script is about helping multipath diagnose with DataCore SSY vDisks
#   it will add FrontEnd info infront of Lun targets
#   coupled with SSY RestAPI it could also add the SSY vDisk name to the Multipath
#
# Usage: ssy-multipath.sh [iscsi|nvme-tcp]
#   (no argument) : display both iSCSI and NVMe/TCP
#   iscsi         : display iSCSI multipath only
#   nvme-tcp      : display NVMe/TCP topology only
#
#############################################################

ERR=0
readonly RED='\033[1;31m'
readonly GREEN='\033[1;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[1;34m'
readonly NC='\033[0m'

# ─── Parameter handling ───────────────────────────────────────────────────────
SHOW_ISCSI=1
SHOW_NVME=1

if [ $# -gt 0 ]; then
    case "$1" in
        iscsi)
            SHOW_ISCSI=1
            SHOW_NVME=0
            ;;
        nvme-tcp)
            SHOW_ISCSI=0
            SHOW_NVME=1
            ;;
        *)
            printf "${RED}Error: Unknown protocol '${1}'. Valid options are: iscsi, nvme-tcp${NC}\n"
            printf "Usage: $(basename $0) [iscsi|nvme-tcp]\n"
            exit 1
            ;;
    esac
fi

# ─── SSY connection by RESTAPI ────────────────────────────────────────────────

if [ -f /etc/pve/storage.cfg ] ; then

  if [ $(whereis jq|wc -w) -le 1 ] ; then
    printf "${RED}JQ package is mandatory to gather data from SSY, please install the package using ${YELLOW}apt install jq${NC}\n"
    VDISKS=""
    FEPORTS=""
  else
    CONNECTED=0
    PVECONF=$(cat /etc/pve/storage.cfg |grep -m1 -A5 ssy:)
    SERVERHOST=$(printf "$PVECONF" |awk '/SSYipAddress/ {print $2}'|sed "s/,/ /g")
    SSYUSER=$(printf "$PVECONF" |awk '/SSYusername/ {print $2}')

    SSY_NAME=$(cat /etc/pve/storage.cfg | grep -m1 'ssy:' | awk '{print $2}')
    SSY_PW_FILE="/etc/pve/priv/storage/${SSY_NAME}.pw"
    SSY_CREDS=""
    if [ -f "$SSY_PW_FILE" ] ; then
      SSYPWD=$(cat "$SSY_PW_FILE" | tr -d '[:space:]' | base64 -d)
      SSY_CREDS="${SSYUSER}:${SSYPWD}"
    fi

    if [[ "$SSY_CREDS" != "" ]]; then
      for SSYHOST in $SERVERHOST
      do
      VDISKS=$(curl -s -m 1 -k -L -H "ServerHost: ${SSYHOST}" -u "${SSY_CREDS}" https://${SSYHOST}/RestService/rest.svc/1.0/virtualdisks)
      FEPORTS=$(curl -s -m 1 -k -L -H "ServerHost: ${SSYHOST}" -u "${SSY_CREDS}" "https://${SSYHOST}/RestService/rest.svc/1.0/ports?supportsNVMeTcpPorts=true" 2>/dev/null)
      if [[ "$VDISKS" != "" ]] ; then
          if ! [ $(echo $VDISKS|jq -e 'try(.ErrorsCode)') ]; then
              CONNECTED=1
              break
          fi
      fi
      done
    fi

    if [ $CONNECTED -ne 1 ]; then
      VDISKS=""
      FEPORTS=""
      printf "${RED}Unable to gather data from SSY, please review if the SSY storage class is added or not. ${NC}\n"
    fi
  fi
else
  VDISKS=""
  FEPORTS=""
fi

fe_port_name_for_ip() {
  local ip="$1"
  if [[ -z "$FEPORTS" || -z "$ip" ]]; then
    echo ""
    return
  fi
  echo "$FEPORTS" | jq -r --arg ip "$ip" '
    .[] |
    select(
      .PortType == 5 and
      .PortMode == 2 and
      (.PortConfigInfo.PortalsConfig[0].Address.Address // "") == $ip
    ) |
    .PortName | split(":") | last
  ' 2>/dev/null | head -1
}

vd_alias_for_ns() {
  local ns_dev="$1"   # e.g. nvme0n1
  if [[ -z "$VDISKS" || -z "$ns_dev" ]]; then
    echo ""
    return
  fi

  local raw_wwid
  raw_wwid=$(cat /sys/block/${ns_dev}/wwid 2>/dev/null)
  raw_wwid="${raw_wwid#uuid.}"
  local wwid_hex
  wwid_hex=$(echo "$raw_wwid" | tr -d '-' | tr '[:lower:]' '[:upper:]')
  if [[ -z "$wwid_hex" || ${#wwid_hex} -ne 32 ]]; then
    echo ""
    return
  fi

  local alias=""
  while IFS=$'	' read -r scsi vd_alias; do
    scsi="${scsi^^}"
    [[ ${#scsi} -eq 32 ]] || continue

    local b6=$(( 16#${scsi:12:2} ))
    local b8=$(( 16#${scsi:16:2} ))
    local f6 f8
    printf -v f6 '%02X' $(( (b6 & 0x0F) | 0x40 ))
    printf -v f8 '%02X' $(( (b8 & 0x3F) | 0x80 ))
    local transformed="${scsi:0:12}${f6}${scsi:14:2}${f8}${scsi:18}"

    if [[ "$transformed" == "$wwid_hex" ]]; then
      alias="$vd_alias"
      break
    fi
  done < <(echo "$VDISKS" | jq -r '.[] | [.ScsiDeviceIdString, .Alias] | @tsv' 2>/dev/null)

  echo "$alias"
}



# ─── iSCSI Multipath ──────────────────────────────────────────────────────────

if [ "$SHOW_ISCSI" -eq 1 ] && command -v multipath &>/dev/null; then

  printf '\n'
  printf '%s\n' "═══════════════════════════════════════════════════════════════════"
  printf '%s\n' "  iSCSI Multipath"
  printf '%s\n' "═══════════════════════════════════════════════════════════════════"

  multipath -r
  sleep 2
  TMP_LL=$(mktemp /tmp/multipath.ll.XXXXXX)
  TMP_V3=$(mktemp /tmp/multipath.v3.XXXXXX)

  multipath -ll > "$TMP_LL"
  multipath -v3 &> "$TMP_V3"

  if [ ! -s "$TMP_LL" ]; then
    printf "${YELLOW}No iSCSI devices found.${NC}\n"
  else
    DEVICES=$(cat $TMP_V3 | awk -F"\||:"  '/\| sd/ {print $2}' |sort -u)

    while IFS= read -r LINE; do
      VDISK=""
      if [ $(echo ${LINE} | grep -c "${DEVICES[*]}") -eq 0  ]; then
        if [ $(echo ${LINE} | grep -c "DataCore,Virtual Disk") -eq 1 ]; then
          NAA=$(echo ${LINE} | awk -F'[()]' '{print substr($2,2)}' | tr '[:lower:]' '[:upper:]')
          if [[ $VDISKS ]] ; then VDISK=$(echo ${VDISKS}|jq --arg name $NAA -r '.[] | select(.ScsiDeviceIdString == $name) | .Alias') ; fi
        fi
        if [[ $VDISK ]] ; then printf "\n${YELLOW}[${VDISK}]${NC} ${LINE} ${YELLOW}[${VDISK}]${NC}\n"
        else
          line_color="$NC"
          if [ $(echo "${LINE}" | grep -c "status=active") -eq 1 ];   then line_color="$GREEN"; fi
          if [ $(echo "${LINE}" | grep -c "status=enabled") -eq 1 ];   then line_color="$BLUE"; fi
          printf "${line_color}${LINE}${NC}\n"
        fi
      else
        DEVICE=$(echo "$LINE" | awk -F"[0-9]+\:[0-9]+\:[0-9]+\:[0-9]" '{print $2}'|awk '{print $1}')
        PORTAL=$(cat $TMP_V3 |awk -F"\| " '{print $2}'| awk '/'$DEVICE': tgt_node_name/ {print $0}'|awk -F":" '{print $3}'|sort -u)
        if [ $(echo "${LINE}" | grep -c "faulty") -eq 0 ]; then
          printf "${GREEN}${LINE} ${YELLOW}($PORTAL)${NC}\n"
        else
          printf "${RED}${LINE} ${YELLOW}($PORTAL)${NC}\n"
        fi
      fi
    done < $TMP_LL
  fi

  rm -f "$TMP_LL" "$TMP_V3"

  printf '%s\n' "+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++"

fi   # end iSCSI block

# ─── NVMe/TCP Multipath ───────────────────────────────────────────────────────
 
if [ "$SHOW_NVME" -eq 1 ] && command -v nvme &>/dev/null; then
 
  printf '\n'
  printf '%s\n' "═══════════════════════════════════════════════════════════════════"
  printf '%s\n' "  NVMe/TCP Multipath"
  printf '%s\n' "═══════════════════════════════════════════════════════════════════"
 
  # ── Native multipath enabled? ───────────────────────────────────────────────
  mp_enabled=$(cat /sys/module/nvme_core/parameters/multipath 2>/dev/null || echo "N")
  if [ "$mp_enabled" = "Y" ]; then
      printf "NVMe native multipath : ${GREEN}enabled${NC}\n\n"
  else
      printf "NVMe native multipath : ${YELLOW}disabled${NC}\n"
      printf "  → ${YELLOW}echo 'options nvme_core multipath=Y' > /etc/modprobe.d/nvme.conf && update-initramfs -u${NC}\n\n"
  fi
 
  # ── Run nvme show-topology ──────────────────────────────────────────────────
  topo_out=$(nvme show-topology 2>/dev/null)
 
  if [ -z "$topo_out" ]; then
      printf "${YELLOW}No NVMe devices found.${NC}\n"
  else
      subsys_buf=""
      block_has_dev=0
      found_any=0

      current_subsys_nqn=""
      declare -A ns_to_bdev
      declare -A ns_to_alias

      flush_color_line() {
          local raw_line="$1"
          local last second_last ana state line_color

          if [[ "$raw_line" =~ \+\-[[:space:]]ns[[:space:]]([0-9]+) ]]; then
              local ns_id="${BASH_REMATCH[1]}"
              local bdev="${ns_to_bdev[$ns_id]:-}"
              local alias="${ns_to_alias[$ns_id]:-}"
              local annotation=""
              if [[ -n "$alias" ]]; then
                annotation=" ${NC}${YELLOW}[${alias}]${NC}${YELLOW}"
              fi
              if [[ -n "$bdev" ]]; then
                annotation+=" (${bdev})"
              fi
              printf "${YELLOW}${raw_line}${annotation}${NC}\n"

          elif [[ "$raw_line" =~ \+\-[[:space:]]nvme[0-9]+[[:space:]]tcp ]]; then
              last=$(        echo "$raw_line" | awk '{print $NF}')
              second_last=$( echo "$raw_line" | awk '{print $(NF-1)}')

              if [[ "$last" =~ ^(optimized|non-optimized|inaccessible|change)$ ]]; then
                  ana="$last"; state="$second_last"
              else
                  state="$last"; ana=""
              fi

              local traddr
              traddr=$(echo "$raw_line" | grep -oP 'traddr=\K[^,\s]+')
              local fe_port=""
              if [[ -n "$traddr" ]]; then
                fe_port=$(fe_port_name_for_ip "$traddr")
              fi

              if   [[ "$state" != "live" ]];                               then line_color="$RED"
              elif [[ "$ana"   == "optimized" ]];                          then line_color="$GREEN"
              elif [[ "$ana"   == "non-optimized" ]];                      then line_color="$BLUE"
              elif [[ "$ana"   == "inaccessible" || "$ana" == "change" ]]; then line_color="$RED"
              else                                                               line_color="$YELLOW"
              fi

              local suffix=""
              [[ -n "$fe_port" ]] && suffix=" ${YELLOW}(${fe_port})${NC}"
              printf "${line_color}${raw_line}${suffix}${NC}\n"

          else
              printf '%s\n' "$raw_line"
          fi
      }

      declare -A subsys_ns_bdev
      declare -A subsys_ns_alias

      for ctrl_path in /sys/class/nvme/nvme*/; do
        ctrl=$(basename "$ctrl_path")
        transport=$(cat "$ctrl_path/transport" 2>/dev/null)
        [[ "$transport" == "tcp" ]] || continue
        nqn=$(cat "$ctrl_path/subsysnqn" 2>/dev/null)
        [[ -n "$nqn" ]] || continue

        for ns_path in "$ctrl_path"nvme*n*; do
          ns_ent=$(basename "$ns_path")
          # Extract subsys and ns numbers from e.g. nvme0c1n3 or nvme0n3
          if [[ "$ns_ent" =~ ^nvme([0-9]+)(c[0-9]+)?n([0-9]+)$ ]]; then
            subsys_num="${BASH_REMATCH[1]}"
            ns_num="${BASH_REMATCH[3]}"
            bdev="nvme${subsys_num}n${ns_num}"
            [[ -d "/sys/block/$bdev" ]] || continue
            nsid=$(cat "/sys/block/$bdev/nsid" 2>/dev/null)
            [[ -n "$nsid" ]] || continue
            key="${nqn}:${nsid}"
            subsys_ns_bdev["$key"]="$bdev"
            alias_val=$(vd_alias_for_ns "$bdev")
            subsys_ns_alias["$key"]="$alias_val"
          fi
        done
      done

      while IFS= read -r line; do
 
          if [[ "$line" =~ ^nvme-subsys ]]; then
              subsys_buf="${YELLOW}${line}${NC}"
              block_has_dev=0
              if [[ "$line" =~ NQN=([^[:space:]]+) ]]; then
                current_subsys_nqn="${BASH_REMATCH[1]}"
              fi
              unset ns_to_bdev ns_to_alias
              declare -A ns_to_bdev
              declare -A ns_to_alias

          elif [[ "$line" =~ hostnqn= ]]; then
              subsys_buf+=$'\n'"${line}"

          elif [[ "$line" =~ \+\-[[:space:]]ns[[:space:]]([0-9]+) ]]; then
              ns_id="${BASH_REMATCH[1]}"
              key="${current_subsys_nqn}:${ns_id}"
              ns_to_bdev["$ns_id"]="${subsys_ns_bdev[$key]:-}"
              ns_to_alias["$ns_id"]="${subsys_ns_alias[$key]:-}"

              if [[ "$block_has_dev" -eq 0 ]]; then
                  printf '%b\n' "$subsys_buf"
                  block_has_dev=1
                  found_any=1
              fi
              flush_color_line "$line"

          elif [[ "$line" =~ \+\-[[:space:]]nvme[0-9]+[[:space:]]tcp ]]; then
              if [[ "$block_has_dev" -eq 0 ]]; then
                  printf '%b\n' "$subsys_buf"
                  block_has_dev=1
                  found_any=1
              fi
              flush_color_line "$line"

          else
              [ "$block_has_dev" -eq 1 ] && printf '%s\n' "$line"
          fi
 
      done <<< "$topo_out"
 
      [ "$found_any" -eq 0 ] && printf "${YELLOW}No NVMe devices found.${NC}\n"
  fi
 
  printf '%s\n' "+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++"
 
fi   # end NVMe block